'use client';

import Link from 'next/link';
import Image from 'next/image';
import { useEffect, useState } from 'react';

interface Profile {
  name: string;
  title: string;
  tagline: string;
  description: string;
  profile_image: string;
  email: string;
  github: string;
  linkedin: string;
  location: string;
}

export default function Home() {
  const [profile, setProfile] = useState<Profile | null>(null);

  useEffect(() => {
    fetch(`${process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000'}/api/profile/me/`)
      .then(res => res.json())
      .then(data => setProfile(data))
      .catch(err => console.error('Error fetching profile:', err));
  }, []);

  return (
    <main className="min-h-screen">
      {/* Hero Section with Image */}
      <section style={{ background: 'linear-gradient(135deg, #E6F2FF 0%, #F8FAFB 100%)', padding: 'clamp(40px, 8vw, 80px) 0' }}>
        <div className="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
          <div className="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center">
            {/* Left Content */}
            <div>
              <div style={{ display: 'inline-block', padding: '6px 14px', backgroundColor: '#E6F2FF', borderRadius: '20px', marginBottom: '16px' }}>
                <span style={{ color: '#0066CC', fontSize: 'clamp(0.75rem, 2vw, 0.875rem)', fontWeight: '600' }}>
                  Welcome to my portfolio
                </span>
              </div>
              
              <h1 style={{ 
                fontSize: 'clamp(2rem, 6vw, 4rem)', 
                fontWeight: '700', 
                marginBottom: 'clamp(16px, 3vw, 24px)',
                lineHeight: '1.1',
                color: '#1A1A1A'
              }}>
                {profile?.name || 'Kur Malual'}
              </h1>
              
              <h2 style={{ 
                fontSize: 'clamp(1.25rem, 4vw, 2rem)', 
                fontWeight: '600', 
                marginBottom: 'clamp(16px, 3vw, 24px)',
                background: 'linear-gradient(135deg, #0066CC 0%, #00A86B 100%)',
                WebkitBackgroundClip: 'text',
                WebkitTextFillColor: 'transparent',
                backgroundClip: 'text'
              }}>
                {profile?.title || 'Full-Stack Software Engineer'}
              </h2>
              
              <p style={{ 
                fontSize: 'clamp(1rem, 2.5vw, 1.125rem)', 
                color: '#6B7280', 
                marginBottom: 'clamp(20px, 4vw, 32px)',
                lineHeight: '1.8'
              }}>
                {profile?.description || 'Software Engineer & CS student. I build scalable platforms for schools, farms, and commerce — with real users from day one.'}
              </p>
              
              <div style={{ display: 'flex', flexWrap: 'wrap', gap: 'clamp(12px, 2vw, 16px)', marginBottom: 'clamp(20px, 4vw, 32px)' }}>
                <Link 
                  href="/projects"
                  style={{
                    padding: 'clamp(12px, 2.5vw, 14px) clamp(24px, 5vw, 32px)',
                    background: 'linear-gradient(135deg, #0066CC 0%, #00A86B 100%)',
                    color: '#FFFFFF',
                    borderRadius: '8px',
                    fontWeight: '600',
                    fontSize: 'clamp(0.9375rem, 2vw, 1rem)',
                    border: 'none',
                    boxShadow: '0 4px 6px -1px rgba(0, 102, 204, 0.3)',
                    transition: 'all 0.3s ease'
                  }}
                  onMouseOver={(e) => e.currentTarget.style.transform = 'translateY(-2px)'}
                  onMouseOut={(e) => e.currentTarget.style.transform = 'translateY(0)'}
                >
                  View My Work
                </Link>
                <Link 
                  href="/contact"
                  style={{
                    padding: 'clamp(12px, 2.5vw, 14px) clamp(24px, 5vw, 32px)',
                    backgroundColor: '#FFFFFF',
                    color: '#0066CC',
                    borderRadius: '8px',
                    fontWeight: '600',
                    fontSize: 'clamp(0.9375rem, 2vw, 1rem)',
                    border: '2px solid #0066CC',
                    transition: 'all 0.3s ease'
                  }}
                  onMouseOver={(e) => {
                    e.currentTarget.style.backgroundColor = '#0066CC';
                    e.currentTarget.style.color = '#FFFFFF';
                  }}
                  onMouseOut={(e) => {
                    e.currentTarget.style.backgroundColor = '#FFFFFF';
                    e.currentTarget.style.color = '#0066CC';
                  }}
                >
                  Get In Touch
                </Link>
              </div>
              
              {/* Social Links */}
              <div style={{ display: 'flex', gap: 'clamp(12px, 2vw, 16px)', alignItems: 'center', flexWrap: 'wrap' }}>
                <span style={{ color: '#6B7280', fontSize: 'clamp(0.8125rem, 2vw, 0.875rem)', fontWeight: '500' }}>Connect:</span>
                <a href={profile?.github || 'https://github.com'} target="_blank" rel="noopener noreferrer" style={{ color: '#0066CC', fontSize: '24px' }}>
                  <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href={profile?.linkedin || 'https://linkedin.com'} target="_blank" rel="noopener noreferrer" style={{ color: '#0066CC', fontSize: '24px' }}>
                  <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <a href={`mailto:${profile?.email || 'kurmalual@gmail.com'}`} style={{ color: '#0066CC', fontSize: '24px' }}>
                  <svg width="24" height="24" fill="currentColor" viewBox="0 0 24 24"><path d="M0 3v18h24v-18h-24zm6.623 7.929l-4.623 5.712v-9.458l4.623 3.746zm-4.141-5.929h19.035l-9.517 7.713-9.518-7.713zm5.694 7.188l3.824 3.099 3.83-3.104 5.612 6.817h-18.779l5.513-6.812zm9.208-1.264l4.616-3.741v9.348l-4.616-5.607z"/></svg>
                </a>
              </div>
            </div>
            
            {/* Right Image */}
            <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center' }}>
              <div style={{ 
                position: 'relative', 
                width: '100%', 
                maxWidth: '500px',
                aspectRatio: '1/1',
                borderRadius: '16px',
                overflow: 'hidden',
                boxShadow: '0 20px 25px -5px rgba(0, 102, 204, 0.2), 0 10px 10px -5px rgba(0, 102, 204, 0.1)',
                background: 'linear-gradient(135deg, #0066CC 0%, #00A86B 100%)'
              }}>
                {profile?.profile_image ? (
                  <Image
                    src={`${process.env.NEXT_PUBLIC_API_URL || 'http://localhost:8000'}${profile.profile_image}`}
                    alt={profile.name}
                    fill
                    style={{ objectFit: 'cover' }}
                    priority
                  />
                ) : (
                  <div style={{ 
                    width: '100%', 
                    height: '100%', 
                    display: 'flex', 
                    alignItems: 'center', 
                    justifyContent: 'center',
                    fontSize: 'clamp(60px, 15vw, 120px)',
                    color: '#FFFFFF'
                  }}>
                    KM
                  </div>
                )}
              </div>
            </div>
          </div>
        </div>
      </section>

      {/* Stats Section */}
      <section style={{ padding: 'clamp(40px, 8vw, 60px) 0', backgroundColor: '#FFFFFF' }}>
        <div className="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
          <div className="grid grid-cols-2 md:grid-cols-4 gap-6 lg:gap-8">
            {[
              { value: '7+', label: 'Projects Completed' },
              { value: '3', label: 'Schools Using DSMS' },
              { value: '40%', label: 'Efficiency Improvement' },
              { value: '2', label: 'Degrees Earned' }
            ].map((stat, index) => (
              <div key={index} style={{ textAlign: 'center' }}>
                <div style={{ 
                  fontSize: 'clamp(1.75rem, 5vw, 3rem)', 
                  fontWeight: '700',
                  background: 'linear-gradient(135deg, #0066CC 0%, #00A86B 100%)',
                  WebkitBackgroundClip: 'text',
                  WebkitTextFillColor: 'transparent',
                  backgroundClip: 'text',
                  marginBottom: '8px'
                }}>
                  {stat.value}
                </div>
                <div style={{ fontSize: 'clamp(0.75rem, 2vw, 0.875rem)', color: '#6B7280', fontWeight: '500' }}>
                  {stat.label}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      {/* Featured Work Preview */}
      <section style={{ padding: 'clamp(40px, 8vw, 80px) 0', backgroundColor: '#F8FAFB' }}>
        <div className="max-w-7xl mx-auto px-6 sm:px-8 lg:px-12">
          <div style={{ textAlign: 'center', marginBottom: 'clamp(40px, 8vw, 60px)' }}>
            <h2 style={{ fontSize: 'clamp(1.75rem, 5vw, 3rem)', fontWeight: '700', marginBottom: '12px', color: '#1A1A1A' }}>
              Featured Work
            </h2>
            <p style={{ fontSize: 'clamp(1rem, 2.5vw, 1.125rem)', color: '#6B7280', maxWidth: '600px', margin: '0 auto', padding: '0 16px' }}>
              Real-world systems deployed and used by actual organizations
            </p>
          </div>
          
          <div style={{ textAlign: 'center' }}>
            <Link 
              href="/projects"
              style={{
                padding: 'clamp(12px, 2.5vw, 14px) clamp(24px, 5vw, 32px)',
                background: 'linear-gradient(135deg, #0066CC 0%, #00A86B 100%)',
                color: '#FFFFFF',
                borderRadius: '8px',
                fontWeight: '600',
                fontSize: 'clamp(0.9375rem, 2vw, 1rem)',
                display: 'inline-block',
                boxShadow: '0 4px 6px -1px rgba(0, 102, 204, 0.3)'
              }}
            >
              View All Projects →
            </Link>
          </div>
        </div>
      </section>
    </main>
  );
}
